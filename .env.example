# Copy to .env and fill in real values. Never commit .env.

# Required: OpenAI API key for ChatOpenAI
OPENAI_API_KEY=

# Optional: identifies HTTP clients (e.g. DuckDuckGo search). Reduces warnings.
USER_AGENT=ProjectNexus/1.0 (dev)

TG_BOT_TOKEN =

TG_ALLOWED_CHAT_IDS =

# Optional: Giphy API key for GIF reactions. Get a free key at developers.giphy.com
GIPHY_API_KEY=
